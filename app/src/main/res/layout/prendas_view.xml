<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@color/white"
    android:clickable="false"
    android:layout_height="420dp">

    <ImageView
        android:id="@+id/imgFotoPrenda"
        android:layout_width="300dp"
        android:layout_height="340dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/logo" />

    <TextView
        android:id="@+id/tvPrecio1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Precio 1"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="@+id/imgFotoPrenda"
        app:layout_constraintStart_toStartOf="@+id/imgFotoPrenda"
        app:layout_constraintTop_toBottomOf="@+id/imgFotoPrenda" />

    <TextView
        android:id="@+id/tvPrecio2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Precio 2"
        android:layout_marginTop="5dp"
        app:layout_constraintEnd_toEndOf="@+id/tvPrecio1"
        app:layout_constraintStart_toStartOf="@+id/tvPrecio1"
        app:layout_constraintTop_toBottomOf="@+id/tvPrecio1" />


    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="25dp"
        android:layout_height="25dp"
        app:layout_constraintBottom_toBottomOf="@+id/imgFotoPrenda"
        app:layout_constraintStart_toStartOf="@+id/imgFotoPrenda"
        app:srcCompat="@color/white" />

    <ImageView
        android:id="@+id/imgDownLoad"
        android:clickable="true"
        android:layout_width="25dp"
        android:layout_height="25dp"
        app:layout_constraintBottom_toBottomOf="@+id/imgFotoPrenda"
        app:layout_constraintStart_toStartOf="@+id/imgFotoPrenda"
        app:srcCompat="@drawable/outline_download_24" />

    <Button
        android:id="@+id/btnEditarPrenda"
        android:layout_width="75dp"
        android:layout_height="30dp"
        android:background="@drawable/borde_redondo"
        android:text="Editar"
        android:visibility="gone"
        android:layout_marginRight="5dp"
        android:layout_marginTop="5dp"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>